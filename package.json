{
  "name": "hooni-labs",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
