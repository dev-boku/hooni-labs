    "format:check": "oxfmt --check .",
    "generate:package": "node scripts/create-package.mjs"
  },
  "devDependencies": {
    "oxlint": "^0.7.0",
    "oxfmt": "^0.2.0",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
